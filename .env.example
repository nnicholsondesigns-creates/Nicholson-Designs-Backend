# Copy this file to ".env" and fill in your real keys.
# Never commit the real ".env" file to GitHub or share it with anyone.

ANTHROPIC_API_KEY=sk-ant-your-key-here
NANOBANANA_API_KEY=your-nanobanana-key-here

# Optional - a free geocoding key from census.gov is not required (US Census geocoder is free, no key needed)
# If you later add a paid GIS/geocoding provider, its key goes here too.

PORT=3001
